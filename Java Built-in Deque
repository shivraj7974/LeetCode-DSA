import java.util.*;

class Main {
    public static void main(String[] args) {
        Deque<Integer> dq = new LinkedList<>();

        dq.addFirst(10);
        dq.addLast(20);
        dq.addFirst(5);

        System.out.println(dq);

        dq.removeLast();
        System.out.println(dq);
    }
}



Important methods:

Method	Meaning
addFirst()	Insert front
addLast()	Insert rear
removeFirst()	Delete front
removeLast()	Delete rear
peekFirst()	See front
peekLast()	See rear
